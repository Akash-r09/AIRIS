# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# ---- App environment ----
# One of: development, production
APP_ENV=development
LOG_LEVEL=INFO

# ---- Backend server ----
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Frontend ----
# Base URL the frontend uses to reach the backend API
FRONTEND_API_BASE_URL=http://localhost:8000

# ---- LLM (Officer Brief Generator, Milestone 11) ----
GEMINI_API_KEY=your-gemini-api-key-here

# ---- NASA FIRMS (fire/stubble-burning data ingestion) ----
# Free registration at https://urs.earthdata.nasa.gov/
EARTHDATA_LOGIN=your-earthdata-username
EARTHDATA_PASSWORD=your-earthdata-password
# Alternative: FIRMS MAP_KEY if using the FIRMS API directly instead of Earthdata login
FIRMS_MAP_KEY=your-firms-map-key-here

# ---- OpenAQ (historical AQI ingestion) ----
# No account required for the public S3 archive; API key only needed for
# higher-rate REST API access if used instead of S3.
OPENAQ_API_KEY=
